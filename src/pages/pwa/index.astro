---
import "../../styles/pwa.css";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#0284C7">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Presence">
    <title>Presence Tracker</title>

    <link rel="icon" type="image/svg+xml" href="../favicon.svg" />
    <link rel="manifest" href="./manifest.json">
    <link rel="apple-touch-icon" href="./icons/icon-192.svg">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">

    <script is:inline src="./config.js"></script>
</head>
<body>
    <div class="pwa-container">
        <div id="auth-screen" class="screen auth-screen">
            <div class="auth-card">
                <div class="auth-logo">
                    <div class="logo-bar"></div>
                    <h1>Presence Tracker</h1>
                </div>
                <p class="auth-subtitle">Clock In & Out</p>

                <div class="auth-content">
                    <p class="auth-description">Sign in with your UCSD Google account to clock in and out.</p>
                    <button id="google-signin-btn" class="btn btn-google" onclick="signInWithGoogle()">
                        <svg class="google-icon" viewBox="0 0 24 24" width="20" height="20">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        Sign in with Google
                    </button>
                </div>

                <div class="install-prompt pwa-hidden" id="install-prompt">
                    <p>Install this app for quick access</p>
                    <button class="btn btn-secondary btn-small" onclick="installPWA()">Install App</button>
                </div>
            </div>
        </div>

        <div id="mismatch-screen" class="screen mismatch-screen pwa-hidden">
            <div class="mismatch-card">
                <div class="mismatch-icon">
                    <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#DC2626" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="15" y1="9" x2="9" y2="15"/>
                        <line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                </div>
                <h2>Email Not Registered</h2>
                <p class="mismatch-email" id="mismatch-email"></p>
                <p class="mismatch-description">This email is not linked to any registered device. Please contact an administrator to register your device first.</p>
                <button class="btn btn-secondary" onclick="signOut()">Sign Out</button>
            </div>
        </div>

        <div id="main-screen" class="screen main-screen pwa-hidden">
            <header class="pwa-header">
                <div class="header-left">
                    <div class="logo-mini">
                        <div class="logo-bar-mini"></div>
                        <span>Presence</span>
                    </div>
                </div>
                <div class="header-right">
                    <button class="btn-icon" onclick="signOut()" title="Sign Out">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                    </button>
                </div>
            </header>

            <main class="pwa-main">
                <div class="user-section">
                    <div class="user-avatar" id="user-avatar">
                        <span id="user-initials">--</span>
                    </div>
                    <div class="user-info">
                        <h2 id="user-name">Loading...</h2>
                        <p id="user-email" class="user-email">--</p>
                    </div>
                </div>

                <div class="status-section">
                    <div class="current-status" id="current-status">
                        <span class="status-label">Current Status</span>
                        <span class="status-value" id="status-value">--</span>
                        <span class="status-subtext" id="status-subtext">--</span>
                    </div>
                </div>

                <div class="location-section" id="location-section">
                    <div class="location-status" id="location-status">
                        <svg class="location-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                        <span id="location-text">Checking location...</span>
                    </div>
                </div>

                <div class="action-section">
                    <button id="clock-btn" class="clock-btn" onclick="toggleClockStatus()" disabled>
                        <span class="clock-btn-text" id="clock-btn-text">Loading...</span>
                    </button>
                    <p class="action-hint" id="action-hint"></p>
                </div>

                <div class="boundary-admin-section pwa-hidden" id="boundary-admin-section">
                    <div class="boundary-admin-header">
                        <h3>Boundary Controls</h3>
                        <span class="boundary-admin-state" id="boundary-admin-state">--</span>
                    </div>
                    <p class="boundary-admin-description">
                        Toggle location boundary enforcement for all PWA check-ins.
                    </p>
                    <label class="boundary-admin-toggle" for="boundary-admin-enabled">
                        <input type="checkbox" id="boundary-admin-enabled">
                        <span class="boundary-admin-toggle-label" id="boundary-admin-toggle-label">Boundary disabled</span>
                    </label>
                    <button class="btn btn-secondary btn-small boundary-admin-save" onclick="saveBoundaryToggle()">
                        Save Boundary Setting
                    </button>
                </div>

                <div class="logs-section">
                    <button class="logs-toggle" id="logs-toggle" onclick="toggleLogsCollapse()" aria-expanded="false">
                        <span id="logs-toggle-text">Show recent activity</span>
                        <svg id="logs-toggle-icon" class="logs-toggle-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9" />
                        </svg>
                    </button>
                    <div class="logs-content collapsed" id="logs-content">
                        <div class="logs-list" id="logs-list">
                            <div class="logs-loading">Loading activity...</div>
                        </div>
                        <div class="logs-pagination" id="logs-pagination">
                            <button class="btn btn-secondary btn-small" id="logs-prev" onclick="changeLogsPage(-1)">Previous</button>
                            <span class="logs-page-indicator" id="logs-page-indicator">Page 1 of 1</span>
                            <button class="btn btn-secondary btn-small" id="logs-next" onclick="changeLogsPage(1)">Next</button>
                        </div>
                    </div>
                </div>
            </main>
        </div>

        <div id="loading-overlay" class="loading-overlay pwa-hidden">
            <div class="spinner"></div>
            <p id="loading-text">Loading...</p>
        </div>

        <div id="toast" class="toast"></div>
    </div>

    <script>
      import "../../scripts/pwa.ts";
    </script>
</body>
</html>
