{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "astro/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.astro",
    "convex/**/*.ts",
    "scripts/**/*.mjs"
  ]
}
